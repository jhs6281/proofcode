{
  "name": "proofcode",
  "displayName": "ProofCode",
  "description": "Verify code changes with reproducible evidence before developers approve them.",
  "version": "0.11.0",
  "publisher": "proofcode",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:proofcode.pingCore",
    "onCommand:proofcode.analyzeCurrentFile",
    "onCommand:proofcode.analyzeWorkspace",
    "onCommand:proofcode.openHotspot",
    "onCommand:proofcode.inspectHotspot",
    "onCommand:proofcode.verifyBaseline",
    "onCommand:proofcode.verifyCandidateFile",
    "onCommand:proofcode.recordCandidateDecision",
    "onCommand:proofcode.viewDecisionHistory",
    "onCommand:proofcode.benchmarkCandidate",
    "onCommand:proofcode.viewBenchmarkHistory"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "proofcode.pingCore",
        "title": "ProofCode: Ping Core"
      },
      {
        "command": "proofcode.analyzeCurrentFile",
        "title": "ProofCode: Analyze Current File"
      },
      {
        "command": "proofcode.analyzeWorkspace",
        "title": "ProofCode: Analyze Workspace"
      },
      {
        "command": "proofcode.openHotspot",
        "title": "ProofCode: Open Hotspot"
      },
      {
        "command": "proofcode.inspectHotspot",
        "title": "ProofCode: Inspect Hotspot Evidence"
      },
      {
        "command": "proofcode.verifyBaseline",
        "title": "ProofCode: Verify Baseline"
      },
      {
        "command": "proofcode.verifyCandidateFile",
        "title": "ProofCode: Verify Candidate File"
      },
      {
        "command": "proofcode.recordCandidateDecision",
        "title": "ProofCode: Record Candidate Decision"
      },
      {
        "command": "proofcode.viewDecisionHistory",
        "title": "ProofCode: View Decision History"
      },
      {
        "command": "proofcode.benchmarkCandidate",
        "title": "ProofCode: Benchmark Candidate"
      },
      {
        "command": "proofcode.viewBenchmarkHistory",
        "title": "ProofCode: View Benchmark History"
      }
    ],
    "configuration": {
      "title": "ProofCode",
      "properties": {
        "proofcode.pythonPath": {
          "type": "string",
          "default": "auto",
          "description": "Python executable. 'auto' prefers core/.venv, then .venv, then system Python."
        },
        "proofcode.includeTests": {
          "type": "boolean",
          "default": false,
          "description": "Include test files in hotspot ranking."
        },
        "proofcode.includeExamples": {
          "type": "boolean",
          "default": false,
          "description": "Include example and fixture files in hotspot ranking."
        },
        "proofcode.benchmarkRuns": {
          "type": "number",
          "default": 5,
          "minimum": 3,
          "maximum": 30,
          "description": "Number of measured test runs for each Baseline and Candidate benchmark."
        },
        "proofcode.benchmarkWarmups": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 5,
          "description": "Number of warm-up runs before measured benchmarks."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:commands": "node scripts/check-commands.mjs",
    "check": "npm run test:commands && npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.7.2"
  }
}
